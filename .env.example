# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (default: SQLite)
SQLITE_PATH=db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/fuelspotter

# Celery/Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# External API Keys (if using paid services)
# GOOGLE_MAPS_API_KEY=your-key-here
# MAPBOX_ACCESS_TOKEN=your-token-here

# Nominatim (OpenStreetMap) - free, no key required
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=FuelSpotter/1.0 (contact@example.com)
NOMINATIM_MIN_INTERVAL_SECONDS=1
NOMINATIM_TIMEOUT_SECONDS=10
GEOCODING_STALE_AFTER_SECONDS=120
GEOCODING_POLL_SECONDS=5
GEOCODING_MAX_RETRIES=5
GEOCODING_AUTO_QUEUE_BATCH_SIZE=500
RUN_APP_ADDRPORT=127.0.0.1:8000
SUPPORTED_COUNTRY_CODES=us

# OSRM (Open Source Routing Machine) - free, no key required
OSRM_BASE_URL=https://router.project-osrm.org
EXTERNAL_HTTP_TIMEOUT_SECONDS=10
